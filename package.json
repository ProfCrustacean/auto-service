{
  "name": "auto-service",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-operable auto service operations system",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "assets:sync": "node src/ui/syncVendorAssets.js",
    "prestart": "npm run assets:sync",
    "pretest": "npm run assets:sync",
    "bootstrap": "npm ci",
    "db:init": "node scripts/db-init.js",
    "plans:compact": "node scripts/compact-plans.js",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "node scripts/static-guardrails.js",
    "hygiene:check": "node scripts/hygiene-check.js",
    "test": "node --test",
    "smoke": "node scripts/smoke.js",
    "audit:bloat": "node scripts/audit-bloat.js",
    "verify": "node scripts/verify.js",
    "secrets:scan": "node scripts/secrets-scan.js",
    "up": "npm ci && npm run verify"
  },
  "dependencies": {
    "@picocss/pico": "2.0.6",
    "express": "^4.21.2"
  }
}
